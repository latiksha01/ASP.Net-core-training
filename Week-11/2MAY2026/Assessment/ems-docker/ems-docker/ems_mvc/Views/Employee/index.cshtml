@model List<ems_mvc.Models.Employee>

<h2>Employee Details</h2>

<a asp-controller="Employee" asp-action="Create" class="btn btn-primary">Add Employee</a>

<table class="table table-bordered mt-3">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Role</th>
            <th>Salary</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var emp in Model)
        {
            <tr>
                <td>@emp.Id</td>
                <td>@emp.Name</td>
                <td>@emp.Role</td>
                <td>@emp.Salary</td>
            </tr>
        }
    </tbody>
</table>